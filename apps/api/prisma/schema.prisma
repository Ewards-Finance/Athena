generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  role              Role               @default(EMPLOYEE)
  isActive          Boolean            @default(true)
  employmentStatus  EmploymentStatus   @default(REGULAR_FULL_TIME)
  adminScope        String?            // "GROUP_ADMIN" | "PAYROLL_ADMIN" | "HR_ADMIN"
  visibilityScope   String?            // "ALL_COMPANIES" | "ASSIGNED_COMPANIES_ONLY"
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]     @relation("EmployeeLeaves")
  managedLeaves     LeaveRequest[]     @relation("ManagerApprovals")
  notifications     Notification[]
  payslipEntries    PayslipEntry[]
  profile           Profile?
  punchMapping      PunchMapping?
  claims            Reimbursement[]
  workLogs          WorkLog[]
  auditLogs         AuditLog[]
  salaryRevisions      SalaryRevision[]
  salaryRevisionsBy    SalaryRevision[]      @relation("SalaryRevisor")
  documents            EmployeeDocument[]
  absenceRecords       AbsenceRecord[]
  attendanceAdjustments AttendanceAdjustment[]
  companyAssignments    EmployeeCompanyAssignment[]
  managedAssignments   EmployeeCompanyAssignment[] @relation("AssignmentManager")
  policyAcknowledgements PolicyAcknowledgement[]
  exitRequest          ExitRequest?
  assetAssignments     AssetAssignment[]
  loanRequests         LoanRequest[]
  compOffs             CompOff[]
  travelProofs         TravelProof[]
  serviceRequests      ServiceRequest[]
  delegationsGiven     DelegateApprover[] @relation("Delegator")
  delegationsReceived  DelegateApprover[] @relation("Delegate")
}

model Profile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  firstName            String
  middleName           String?
  lastName             String
  dateOfBirth          DateTime?
  gender               String?
  bloodGroup           String?
  personalEmail        String?
  phone                String?
  secondaryPhone       String?
  emergencyContact     String?
  employeeId           String    @unique
  designation          String    @default("")
  department           String    @default("")
  dateOfJoining        DateTime?
  officeLocation       String?   @default("Kolkata")
  managerId            String?
  pan                  String?
  aadharNumber         String?
  uan                  String?
  bankAccountNumber    String    @default("")
  ifscCode             String    @default("")
  bankName             String    @default("")
  kycDocumentUrl       String?
  appointmentLetterUrl String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  annualCtc            Float     @default(0)
  employmentType       String    @default("FULL_TIME") // "FULL_TIME" | "INTERN"
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id             String      @id @default(cuid())
  employeeId     String
  managerId      String?
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  totalDays      Float
  reason         String
  status         LeaveStatus @default(PENDING)
  managerComment String?
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  durationType   String?
  singleDayType  String?
  startDayType   String?
  endDayType     String?
  employee       User        @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  manager        User?       @relation("ManagerApprovals", fields: [managerId], references: [id])
  travelProofs   TravelProof[]
}

model Reimbursement {
  id          String        @id @default(cuid())
  employeeId  String
  category    ClaimCategory
  amount      Float
  description String
  billUrl     String?
  status      ClaimStatus   @default(PENDING)
  paidAt      DateTime?
  paidNote    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    User          @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  leaveType String
  total     Float
  used      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, leaveType])
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  type      String?
  createdAt DateTime @default(now())
}

model LeavePolicy {
  id                  String   @id @default(cuid())
  leaveType           String   @unique
  label               String
  defaultTotal        Int
  isActive            Boolean  @default(true)
  isUnlimited         Boolean  @default(false) // true for TEMPORARY_WFH and TRAVELLING — no balance tracking
  documentRequired    Boolean  @default(false)  // medical doc required for this leave type
  documentAfterDays   Int?                      // doc required only if leave > X days (e.g. 2 for SL)
  carryForwardEnabled Boolean  @default(false)
  carryForwardMaxDays Int?                      // max days that can carry over to next year
  encashable          Boolean  @default(false)  // can be encashed on exit
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdBy String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayrollComponent {
  id        String        @id @default(cuid())
  name      String        @unique
  type      ComponentType
  calcType  CalcType
  value     Float         @default(0)
  isActive  Boolean       @default(true)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PayrollRun {
  id              String          @id @default(cuid())
  month           Int
  year            Int
  status          PayrollStatus   @default(DRAFT)
  processedBy     String
  companyId       String?
  company         Company?        @relation(fields: [companyId], references: [id])
  policyVersionId String?
  policyVersion   PolicyVersion?  @relation(fields: [policyVersionId], references: [id])
  runType         PayrollRunType  @default(REGULAR)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  entries         PayslipEntry[]

  @@unique([month, year, companyId, runType])
}

model PayslipEntry {
  id                  String     @id @default(cuid())
  payrollRunId        String
  userId              String
  monthlyCtc          Float
  workingDays         Int
  lwpDays             Float      @default(0)
  paidDays            Float
  earnings            Json
  deductions          Json
  reimbursements      Float      @default(0)
  grossPay            Float
  totalDeductions     Float
  netPay              Float
  // Company snapshot (stamped at payroll time, immutable)
  companyLegalName    String?
  companyAddress      String?
  companyPan          String?
  employeeCode        String?
  designationSnapshot String?
  // Arrears
  arrearsAmount       Float?     @default(0)
  arrearsNote         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  user                User       @relation(fields: [userId], references: [id])

  @@unique([payrollRunId, userId])
}

model WorkLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String

  // Auto-APPROVED on submit; manager can optionally REJECT
  status        String    @default("APPROVED") // "APPROVED" | "REJECTED"
  rejectedBy    String?   // User.id of manager/admin who rejected
  rejectedAt    DateTime?
  rejectionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// DeclaredWFH: HR Admin can declare specific dates as company-wide WFH
// All employees must submit a worklog for these dates — missing = LWP deduction
model DeclaredWFH {
  id        String   @id @default(cuid())
  date      DateTime // midnight UTC
  reason    String?
  createdBy String   // User.id of admin

  createdAt DateTime @default(now())

  @@unique([date])
}

model PunchMapping {
  id        String   @id @default(cuid())
  enNo      Int      @unique
  userId    String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AttendanceImport {
  id            String             @id @default(cuid())
  month         Int
  year          Int
  fileName      String
  importedBy      String
  recordCount     Int
  unmappedEnNos   Json
  arrivalTime     String?           // "HH:MM" — standard cutoff; null = policy not yet applied
  extensionDates  Json @default("[]") // string[] of "YYYY-MM-DD" — days with 11:00 AM cutoff
  createdAt       DateTime           @default(now())
  records         AttendanceRecord[]

  @@unique([month, year])
}

model AttendanceRecord {
  id            String           @id @default(cuid())
  userId        String
  importId      String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  hoursWorked   Float?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  checkInManual DateTime?
  isLate        Boolean          @default(false)
  lwpDeduction  Float            @default(0)
  import        AttendanceImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

// ─── V3.1 New Models ─────────────────────────────────────────────────────────

model Company {
  id            String   @id @default(cuid())
  code          String   @unique  // e.g. "EWARDS-ENGAGEMENT"
  legalName     String            // Full legal name on payslip
  displayName   String            // Short name for UI
  payrollPrefix String?           // e.g. "EE" for employee codes
  pan           String?
  tan           String?
  gstin         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  logoUrl       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments     EmployeeCompanyAssignment[]
  payrollRuns     PayrollRun[]
  policyVersions  PolicyVersion[]
}

model EmployeeCompanyAssignment {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id])
  employeeCode       String?          // Company-specific employee code
  designation        String?          // May differ from group-level designation
  department         String?
  reportingManagerId String?
  reportingManager   User?            @relation("AssignmentManager", fields: [reportingManagerId], references: [id])
  annualCTC          Float?           // CTC under this assignment
  employmentType     String?          // may differ per assignment
  joiningDate        DateTime?        // date joined THIS company (not group)
  effectiveFrom      DateTime         // when this assignment started
  effectiveTo        DateTime?        // null = currently active
  isPrimary          Boolean          @default(true)
  status             AssignmentStatus @default(ACTIVE)
  notes              String?          // reason for transfer, etc.
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([userId, status])
  @@index([companyId])
}

enum PolicyScope {
  GLOBAL           // applies to all companies (default)
  COMPANY_SPECIFIC // overrides global for a specific company
}

model PolicyVersion {
  id             String      @id @default(cuid())
  name           String
  versionCode    String      @unique
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean     @default(false)
  scope          PolicyScope @default(GLOBAL)
  companyId      String?     // only set when scope = COMPANY_SPECIFIC
  company        Company?    @relation(fields: [companyId], references: [id])
  notes          String?
  publishedBy    String?
  publishedAt    DateTime?
  createdAt      DateTime    @default(now())

  rules            PolicyRule[]
  payrollRuns      PayrollRun[]
  acknowledgements PolicyAcknowledgement[]
}

model PolicyRule {
  id              String        @id @default(cuid())
  policyVersionId String
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  ruleKey         String        // e.g. "wfh_deduction_pct"
  ruleValue       String        // e.g. "30"
  valueType       String        // "number" | "boolean" | "string" | "time"
  description     String?
  createdAt       DateTime      @default(now())

  @@unique([policyVersionId, ruleKey])
}

model PolicyAcknowledgement {
  id              String        @id @default(cuid())
  policyVersionId String
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  acknowledgedAt  DateTime?
  isAcknowledged  Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@unique([policyVersionId, userId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClaimCategory {
  TRAVEL
  FOOD
  INTERNET
  MISCELLANEOUS
}

enum ClaimStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum CalcType {
  PERCENTAGE_OF_CTC
  FIXED
  MANUAL
  AUTO_PT
  AUTO_TDS
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  FINALIZED
}

enum PayrollRunType {
  REGULAR
  FULL_AND_FINAL
}

enum EmploymentStatus {
  PENDING_JOIN
  PROBATION
  INTERNSHIP
  REGULAR_FULL_TIME
  NOTICE_PERIOD
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  TRANSFERRED
  CLOSED
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  action        String
  entity        String
  entityId      String?
  subjectEntity String?
  subjectId     String?
  subjectLabel  String?
  subjectMeta   Json?
  oldValues     Json?
  newValues     Json?
  reason        String?       // mandatory for sensitive actions
  changeSource  String?       // "WEB" | "IMPORT" | "API" | "WHATSAPP"
  createdAt     DateTime @default(now())
  actor         User     @relation(fields: [actorId], references: [id])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model SalaryRevision {
  id            String   @id @default(cuid())
  userId        String
  effectiveDate DateTime
  oldCtc        Float
  newCtc        Float
  reason        String?
  revisedBy     String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisor       User     @relation("SalaryRevisor", fields: [revisedBy], references: [id])
}

model EmployeeDocument {
  id          String      @id @default(cuid())
  userId      String
  category    DocCategory @default(OTHER)
  name        String
  fileUrl     String
  description String?
  uploadedBy  String
  expiryDate  DateTime?   // for contract, visa, medical cert, etc.
  isRequired  Boolean     @default(false) // mandatory document flag
  reminderSentAt DateTime? // last expiry reminder sent
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DocCategory {
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  KYC
  CONTRACT
  PAYSLIP
  OTHER
}

model AbsenceRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  markedBy  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── Attendance Adjustment ────────────────────────────────────────────────────
// HR Admin can set a per-employee per-month adjustment to correct attendance
// before payroll is run. Positive = add present days (reduces LWP),
// Negative = add absent/LWP days (increases LWP).
// Example: employee punched in on a day with no fingerprint data → HR adds +1.
// Applied in payroll run creation: final_lwp = computed_lwp - adjustmentDays.
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique // SHA-256 hash of the full key
  prefix      String    @unique // first 12 chars displayed in UI, used for lookup
  createdBy   String
  isActive    Boolean   @default(true)
  scopes      Json
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model BackupLog {
  id          String   @id @default(cuid())
  triggeredBy String   // "SCHEDULED" or userId
  status      String   // "RUNNING" | "SUCCESS" | "FAILED"
  fileName    String?
  commitSha   String?
  fileSizeKb  Int?
  error       String?
  createdAt   DateTime @default(now())
}

model AttendanceAdjustment {
  id             String   @id @default(cuid())
  userId         String
  month          Int
  year           Int
  adjustmentDays Float    // +ve = reduce LWP (employee worked more than recorded), -ve = add LWP
  reason         String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

// ─── V3.1 Sprint 2: Exit Management ──────────────────────────────────────────

model ExitRequest {
  id               String     @id @default(cuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id])
  initiatedBy      String     // userId — self-resignation or admin-initiated
  reason           String
  lastWorkingDate  DateTime
  noticePeriodDays Int        // configurable per exit
  buyoutDays       Int?       // days bought out (reduces notice period)
  buyoutAmount     Float?     // recovery deducted in final settlement
  status           ExitStatus @default(INITIATED)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  clearances       ExitClearance[]
  settlement       FinalSettlement?
}

model ExitClearance {
  id            String          @id @default(cuid())
  exitRequestId String
  exitRequest   ExitRequest     @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
  department    String          // "IT" | "Finance" | "HR" | "Admin" | "Manager"
  clearedBy     String?         // userId of who cleared
  status        ClearanceStatus @default(PENDING)
  remarks       String?
  clearedAt     DateTime?
  createdAt     DateTime        @default(now())
}

model FinalSettlement {
  id                      String      @id @default(cuid())
  exitRequestId           String      @unique
  exitRequest             ExitRequest @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)

  // Earnings
  lastMonthSalaryProrated Float       // pro-rated salary for final partial month
  leaveEncashmentDays     Float       // balance days eligible for encashment
  leaveEncashmentAmount   Float
  pendingClaimsAmount     Float       @default(0)
  arrearsPending          Float       @default(0)
  bonusPending            Float       @default(0)

  // Deductions
  noticePeriodRecovery    Float       @default(0)  // if left short of notice
  loanOutstanding         Float       @default(0)  // remaining loan balance
  otherDeductions         Float       @default(0)

  totalPayable            Float       // = earnings - deductions
  processedBy             String?     // userId
  processedAt             DateTime?
  createdAt               DateTime    @default(now())
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  SETTLED
  CANCELLED
}

enum ClearanceStatus {
  PENDING
  CLEARED
}

// ─── V3.1 Sprint 2: Asset Management ─────────────────────────────────────────

model Asset {
  id            String        @id @default(cuid())
  name          String        // "MacBook Pro 14"
  assetTag      String        @unique // "EWRD-LAP-001"
  category      AssetCategory
  serialNumber  String?
  purchaseDate  DateTime?
  purchaseCost  Float?
  status        AssetStatus   @default(AVAILABLE)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignments   AssetAssignment[]
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  conditionOut String?   // condition when issued
  conditionIn  String?   // condition when returned
  notes        String?
  assignedBy   String    // userId of admin

  @@index([assetId])
  @@index([userId])
}

enum AssetCategory {
  LAPTOP
  PHONE
  CHARGER
  MONITOR
  KEYBOARD
  MOUSE
  SIM_CARD
  ACCESS_CARD
  ID_CARD
  SOFTWARE_LICENSE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

// ─── V3.1 Sprint 2: Import Batch ─────────────────────────────────────────────

model ImportBatch {
  id          String       @id @default(cuid())
  type        ImportType
  uploadedBy  String
  fileName    String
  totalRows   Int
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  status      ImportStatus @default(PREVIEWED)
  errorLog    String?      // JSON string of row-level errors
  notes       String?      // JSON string of parsed data for preview/commit flow
  createdAt   DateTime     @default(now())
}

enum ImportType {
  ATTENDANCE
  EMPLOYEE_BULK
  ASSET_BULK
}

enum ImportStatus {
  PREVIEWED
  IMPORTED
  PARTIALLY_IMPORTED
  ROLLED_BACK
}

// ─── V3.1 Sprint 3: Loans ──────────────────────────────────────────────────────

model LoanRequest {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id])
  amount           Float
  installments     Int        // number of months for deduction
  monthlyEMI       Float      // computed via reducing-balance EMI formula
  interestRate     Float      @default(9.0)  // annual % rate at time of approval
  reason           String
  status           LoanStatus @default(PENDING)
  approvedBy       String?
  approvedAt       DateTime?
  startMonth       Int?       // 1-12, month EMI deductions start
  startYear        Int?
  paidInstallments Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  CLOSED
  REJECTED
}

// ─── V3.1 Sprint 3: Comp-Off ────────────────────────────────────────────────────

model CompOff {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  earnedDate  DateTime      // holiday/weekend day they worked on
  reason      String
  status      CompOffStatus @default(PENDING)
  approvedBy  String?
  usedOn      DateTime?     // date they consumed comp-off as leave
  expiresAt   DateTime      // earnedDate + compoff_expiry_days from PolicyRule
  createdAt   DateTime      @default(now())

  @@unique([userId, earnedDate])
}

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  USED
}

// ─── V3.1 Sprint 3: Travel Proof ────────────────────────────────────────────────

model TravelProof {
  id              String       @id @default(cuid())
  leaveRequestId  String
  leaveRequest    LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  proofDate       DateTime     // the specific travel day this proof covers
  geoLat          Float?       // GPS latitude
  geoLng          Float?       // GPS longitude
  mapsLink        String?      // https://maps.google.com/?q={lat},{lng}
  submittedAt     DateTime?
  createdAt       DateTime     @default(now())

  @@unique([leaveRequestId, proofDate])
}

// ─── V3.1 Sprint 5: Service Desk ────────────────────────────────────────────

model ServiceRequest {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id])
  category    ServiceRequestCategory
  subject     String
  description String
  status      ServiceRequestStatus   @default(OPEN)
  assignedTo  String?                // HR admin userId
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

enum ServiceRequestCategory {
  SALARY_ISSUE
  ATTENDANCE_CORRECTION
  DOCUMENT_REQUEST
  REIMBURSEMENT_ISSUE
  LEAVE_CORRECTION
  LETTER_REQUEST
  IT_SUPPORT
  OTHER
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── V3.1 Sprint 5: Delegate Approver ───────────────────────────────────────

model DelegateApprover {
  id           String   @id @default(cuid())
  delegatorId  String
  delegator    User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegateId   String
  delegate     User     @relation("Delegate", fields: [delegateId], references: [id])
  fromDate     DateTime
  toDate       DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
