generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AbsenceRecord {
  id        String   @id
  userId    String
  date      DateTime
  markedBy  String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Announcement {
  id        String   @id
  title     String
  body      String
  createdBy String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model ApiKey {
  id         String    @id
  name       String
  keyHash    String    @unique
  prefix     String    @unique
  createdBy  String
  isActive   Boolean   @default(true)
  scopes     Json
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Asset {
  id              String            @id
  name            String
  assetTag        String            @unique
  category        AssetCategory
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseCost    Float?
  status          AssetStatus       @default(AVAILABLE)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  AssetAssignment AssetAssignment[]
}

model AssetAssignment {
  id           String    @id
  assetId      String
  userId       String
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  conditionOut String?
  conditionIn  String?
  notes        String?
  assignedBy   String
  Asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@index([userId])
}

model AttendanceAdjustment {
  id             String   @id
  userId         String
  month          Int
  year           Int
  adjustmentDays Float
  reason         String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model AttendanceImport {
  id               String             @id
  month            Int
  year             Int
  fileName         String
  importedBy       String
  recordCount      Int
  unmappedEnNos    Json
  arrivalTime      String?
  extensionDates   Json               @default("[]")
  createdAt        DateTime           @default(now())
  AttendanceRecord AttendanceRecord[]

  @@unique([month, year])
}

model AttendanceRecord {
  id               String           @id
  userId           String
  importId         String
  date             DateTime
  checkIn          DateTime?
  checkOut         DateTime?
  hoursWorked      Float?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  checkInManual    DateTime?
  isLate           Boolean          @default(false)
  lwpDeduction     Float            @default(0)
  AttendanceImport AttendanceImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  User             User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model AuditLog {
  id            String   @id
  actorId       String
  action        String
  entity        String
  entityId      String?
  subjectEntity String?
  subjectId     String?
  subjectLabel  String?
  subjectMeta   Json?
  oldValues     Json?
  newValues     Json?
  reason        String?
  changeSource  String?
  createdAt     DateTime @default(now())
  User          User     @relation(fields: [actorId], references: [id])
}

model BackupLog {
  id          String   @id
  triggeredBy String
  status      String
  fileName    String?
  commitSha   String?
  fileSizeKb  Int?
  error       String?
  createdAt   DateTime @default(now())
}

model CompOff {
  id         String        @id
  userId     String
  earnedDate DateTime
  reason     String
  status     CompOffStatus @default(PENDING)
  approvedBy String?
  usedOn     DateTime?
  expiresAt  DateTime
  createdAt  DateTime      @default(now())
  User       User          @relation(fields: [userId], references: [id])

  @@unique([userId, earnedDate])
}

model Company {
  id                        String                      @id
  code                      String                      @unique
  legalName                 String
  displayName               String
  payrollPrefix             String?
  pan                       String?
  tan                       String?
  gstin                     String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  state                     String?
  pincode                   String?
  logoUrl                   String?
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  EmployeeCompanyAssignment EmployeeCompanyAssignment[]
  PayrollRun                PayrollRun[]
  PolicyVersion             PolicyVersion[]
}

model DeclaredWFH {
  id        String   @id
  date      DateTime @unique
  reason    String?
  createdBy String
  createdAt DateTime @default(now())
}

model DelegateApprover {
  id                                      String   @id
  delegatorId                             String
  delegateId                              String
  fromDate                                DateTime
  toDate                                  DateTime
  isActive                                Boolean  @default(true)
  createdAt                               DateTime @default(now())
  User_DelegateApprover_delegateIdToUser  User     @relation("DelegateApprover_delegateIdToUser", fields: [delegateId], references: [id])
  User_DelegateApprover_delegatorIdToUser User     @relation("DelegateApprover_delegatorIdToUser", fields: [delegatorId], references: [id])
}

model EmployeeCompanyAssignment {
  id                                                      String           @id
  userId                                                  String
  companyId                                               String
  employeeCode                                            String?
  designation                                             String?
  department                                              String?
  reportingManagerId                                      String?
  annualCTC                                               Float?
  employmentType                                          String?
  joiningDate                                             DateTime?
  effectiveFrom                                           DateTime
  effectiveTo                                             DateTime?
  isPrimary                                               Boolean          @default(true)
  status                                                  AssignmentStatus @default(ACTIVE)
  notes                                                   String?
  createdAt                                               DateTime         @default(now())
  updatedAt                                               DateTime
  Company                                                 Company          @relation(fields: [companyId], references: [id])
  User_EmployeeCompanyAssignment_reportingManagerIdToUser User?            @relation("EmployeeCompanyAssignment_reportingManagerIdToUser", fields: [reportingManagerId], references: [id])
  User_EmployeeCompanyAssignment_userIdToUser             User             @relation("EmployeeCompanyAssignment_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId, status])
}

model EmployeeDocument {
  id             String      @id
  userId         String
  category       DocCategory @default(OTHER)
  name           String
  fileUrl        String
  description    String?
  uploadedBy     String
  expiryDate     DateTime?
  isRequired     Boolean     @default(false)
  reminderSentAt DateTime?
  createdAt      DateTime    @default(now())
  User           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExitClearance {
  id            String          @id
  exitRequestId String
  department    String
  clearedBy     String?
  status        ClearanceStatus @default(PENDING)
  remarks       String?
  clearedAt     DateTime?
  createdAt     DateTime        @default(now())
  ExitRequest   ExitRequest     @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
}

model ExitRequest {
  id               String           @id
  userId           String           @unique
  initiatedBy      String
  reason           String
  lastWorkingDate  DateTime
  noticePeriodDays Int
  buyoutDays       Int?
  buyoutAmount     Float?
  status           ExitStatus       @default(INITIATED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  ExitClearance    ExitClearance[]
  User             User             @relation(fields: [userId], references: [id])
  FinalSettlement  FinalSettlement?
}

model FinalSettlement {
  id                      String      @id
  exitRequestId           String      @unique
  lastMonthSalaryProrated Float
  leaveEncashmentDays     Float
  leaveEncashmentAmount   Float
  pendingClaimsAmount     Float       @default(0)
  arrearsPending          Float       @default(0)
  bonusPending            Float       @default(0)
  noticePeriodRecovery    Float       @default(0)
  loanOutstanding         Float       @default(0)
  otherDeductions         Float       @default(0)
  totalPayable            Float
  processedBy             String?
  processedAt             DateTime?
  createdAt               DateTime    @default(now())
  ExitRequest             ExitRequest @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id
  name      String
  date      DateTime
  type      String?
  createdAt DateTime @default(now())
}

model ImportBatch {
  id          String       @id
  type        ImportType
  uploadedBy  String
  fileName    String
  totalRows   Int
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  status      ImportStatus @default(PREVIEWED)
  errorLog    String?
  notes       String?
  createdAt   DateTime     @default(now())
}

model LeaveBalance {
  id        String   @id
  userId    String
  year      Int
  leaveType String
  total     Float
  used      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, leaveType])
}

model LeavePolicy {
  id                  String   @id
  leaveType           String   @unique
  label               String
  defaultTotal        Int
  isActive            Boolean  @default(true)
  isUnlimited         Boolean  @default(false)
  documentRequired    Boolean  @default(false)
  documentAfterDays   Int?
  carryForwardEnabled Boolean  @default(false)
  carryForwardMaxDays Int?
  encashable          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime
}

model LeaveRequest {
  id                                 String        @id
  employeeId                         String
  managerId                          String?
  leaveType                          String
  startDate                          DateTime
  endDate                            DateTime
  totalDays                          Float
  reason                             String
  status                             LeaveStatus   @default(PENDING)
  managerComment                     String?
  approvedAt                         DateTime?
  createdAt                          DateTime      @default(now())
  updatedAt                          DateTime
  durationType                       String?
  singleDayType                      String?
  startDayType                       String?
  endDayType                         String?
  User_LeaveRequest_employeeIdToUser User          @relation("LeaveRequest_employeeIdToUser", fields: [employeeId], references: [id])
  User_LeaveRequest_managerIdToUser  User?         @relation("LeaveRequest_managerIdToUser", fields: [managerId], references: [id])
  TravelProof                        TravelProof[]
}

model LoanRequest {
  id               String     @id
  userId           String
  amount           Float
  installments     Int
  monthlyEMI       Float
  interestRate     Float      @default(9.0)
  reason           String
  status           LoanStatus @default(PENDING)
  approvedBy       String?
  approvedAt       DateTime?
  startMonth       Int?
  startYear        Int?
  paidInstallments Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime
  User             User       @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayrollComponent {
  id        String        @id
  name      String        @unique
  type      ComponentType
  calcType  CalcType
  value     Float         @default(0)
  isActive  Boolean       @default(true)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime
}

model PayrollRun {
  id              String         @id
  month           Int
  year            Int
  status          PayrollStatus  @default(DRAFT)
  processedBy     String
  companyId       String?
  policyVersionId String?
  runType         PayrollRunType @default(REGULAR)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  Company         Company?       @relation(fields: [companyId], references: [id])
  PolicyVersion   PolicyVersion? @relation(fields: [policyVersionId], references: [id])
  PayslipEntry    PayslipEntry[]

  @@unique([month, year, companyId, runType])
}

model PayslipEntry {
  id                  String     @id
  payrollRunId        String
  userId              String
  monthlyCtc          Float
  workingDays         Int
  lwpDays             Float      @default(0)
  paidDays            Float
  earnings            Json
  deductions          Json
  reimbursements      Float      @default(0)
  grossPay            Float
  totalDeductions     Float
  netPay              Float
  companyLegalName    String?
  companyAddress      String?
  companyPan          String?
  employeeCode        String?
  designationSnapshot String?
  arrearsAmount       Float?     @default(0)
  arrearsNote         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime
  PayrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  User                User       @relation(fields: [userId], references: [id])

  @@unique([payrollRunId, userId])
}

model PolicyAcknowledgement {
  id              String        @id
  policyVersionId String
  userId          String
  acknowledgedAt  DateTime?
  isAcknowledged  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  PolicyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  User            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([policyVersionId, userId])
}

model PolicyRule {
  id              String        @id
  policyVersionId String
  ruleKey         String
  ruleValue       String
  valueType       String
  description     String?
  createdAt       DateTime      @default(now())
  PolicyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)

  @@unique([policyVersionId, ruleKey])
}

model PolicyVersion {
  id                    String                  @id
  name                  String
  versionCode           String                  @unique
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  isActive              Boolean                 @default(false)
  scope                 PolicyScope             @default(GLOBAL)
  companyId             String?
  notes                 String?
  publishedBy           String?
  publishedAt           DateTime?
  createdAt             DateTime                @default(now())
  PayrollRun            PayrollRun[]
  PolicyAcknowledgement PolicyAcknowledgement[]
  PolicyRule            PolicyRule[]
  Company               Company?                @relation(fields: [companyId], references: [id])
}

model Profile {
  id                   String    @id
  userId               String    @unique
  firstName            String
  middleName           String?
  lastName             String
  dateOfBirth          DateTime?
  gender               String?
  bloodGroup           String?
  personalEmail        String?
  phone                String?
  secondaryPhone       String?
  emergencyContact     String?
  employeeId           String    @unique
  designation          String    @default("")
  department           String    @default("")
  dateOfJoining        DateTime?
  officeLocation       String?   @default("Kolkata")
  managerId            String?
  pan                  String?
  aadharNumber         String?
  uan                  String?
  bankAccountNumber    String    @default("")
  ifscCode             String    @default("")
  bankName             String    @default("")
  kycDocumentUrl       String?
  appointmentLetterUrl String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  annualCtc            Float     @default(0)
  employmentType       String    @default("FULL_TIME")
  User                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PunchMapping {
  id        String   @id
  enNo      Int      @unique
  userId    String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id          String        @id
  employeeId  String
  category    ClaimCategory
  amount      Float
  description String
  billUrl     String?
  status      ClaimStatus   @default(PENDING)
  paidAt      DateTime?
  paidNote    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  User        User          @relation(fields: [employeeId], references: [id])
}

model SalaryRevision {
  id                                  String         @id
  userId                              String
  effectiveDate                       DateTime
  oldCtc                              Float
  newCtc                              Float
  reason                              String?
  revisedBy                           String
  status                              RevisionStatus @default(PENDING)
  proposedBy                          String
  approvedBy                          String?
  createdAt                           DateTime       @default(now())
  User_SalaryRevision_revisedByToUser User           @relation("SalaryRevision_revisedByToUser", fields: [revisedBy], references: [id])
  User_SalaryRevision_userIdToUser    User           @relation("SalaryRevision_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceRequest {
  id          String                 @id
  userId      String
  category    ServiceRequestCategory
  subject     String
  description String
  status      ServiceRequestStatus   @default(OPEN)
  assignedTo  String?
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime
  User        User                   @relation(fields: [userId], references: [id])
}

model SystemSetting {
  id        String   @id
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime
}

model TravelProof {
  id             String       @id
  leaveRequestId String
  userId         String
  proofDate      DateTime
  geoLat         Float?
  geoLng         Float?
  mapsLink       String?
  submittedAt    DateTime?
  createdAt      DateTime     @default(now())
  LeaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  User           User         @relation(fields: [userId], references: [id])

  @@unique([leaveRequestId, proofDate])
}

model User {
  id                                                                           String                      @id
  email                                                                        String                      @unique
  password                                                                     String
  role                                                                         Role                        @default(EMPLOYEE)
  isActive                                                                     Boolean                     @default(true)
  employmentStatus                                                             EmploymentStatus            @default(REGULAR_FULL_TIME)
  adminScope                                                                   String?
  visibilityScope                                                              String?
  createdAt                                                                    DateTime                    @default(now())
  updatedAt                                                                    DateTime
  AbsenceRecord                                                                AbsenceRecord[]
  AssetAssignment                                                              AssetAssignment[]
  AttendanceAdjustment                                                         AttendanceAdjustment[]
  AttendanceRecord                                                             AttendanceRecord[]
  AuditLog                                                                     AuditLog[]
  CompOff                                                                      CompOff[]
  DelegateApprover_DelegateApprover_delegateIdToUser                           DelegateApprover[]          @relation("DelegateApprover_delegateIdToUser")
  DelegateApprover_DelegateApprover_delegatorIdToUser                          DelegateApprover[]          @relation("DelegateApprover_delegatorIdToUser")
  EmployeeCompanyAssignment_EmployeeCompanyAssignment_reportingManagerIdToUser EmployeeCompanyAssignment[] @relation("EmployeeCompanyAssignment_reportingManagerIdToUser")
  EmployeeCompanyAssignment_EmployeeCompanyAssignment_userIdToUser             EmployeeCompanyAssignment[] @relation("EmployeeCompanyAssignment_userIdToUser")
  EmployeeDocument                                                             EmployeeDocument[]
  ExitRequest                                                                  ExitRequest?
  LeaveBalance                                                                 LeaveBalance[]
  LeaveRequest_LeaveRequest_employeeIdToUser                                   LeaveRequest[]              @relation("LeaveRequest_employeeIdToUser")
  LeaveRequest_LeaveRequest_managerIdToUser                                    LeaveRequest[]              @relation("LeaveRequest_managerIdToUser")
  LoanRequest                                                                  LoanRequest[]
  Notification                                                                 Notification[]
  PayslipEntry                                                                 PayslipEntry[]
  PolicyAcknowledgement                                                        PolicyAcknowledgement[]
  Profile                                                                      Profile?
  PunchMapping                                                                 PunchMapping?
  Reimbursement                                                                Reimbursement[]
  SalaryRevision_SalaryRevision_revisedByToUser                                SalaryRevision[]            @relation("SalaryRevision_revisedByToUser")
  SalaryRevision_SalaryRevision_userIdToUser                                   SalaryRevision[]            @relation("SalaryRevision_userIdToUser")
  ServiceRequest                                                               ServiceRequest[]
  TravelProof                                                                  TravelProof[]
  WorkLog                                                                      WorkLog[]
}

model WorkLog {
  id            String    @id
  userId        String
  date          DateTime
  content       String
  status        String    @default("APPROVED")
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  User          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum AssetCategory {
  LAPTOP
  PHONE
  CHARGER
  MONITOR
  KEYBOARD
  MOUSE
  SIM_CARD
  ACCESS_CARD
  ID_CARD
  SOFTWARE_LICENSE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

enum AssignmentStatus {
  ACTIVE
  TRANSFERRED
  CLOSED
}

enum CalcType {
  PERCENTAGE_OF_CTC
  FIXED
  MANUAL
  AUTO_PT
  AUTO_TDS
}

enum ClaimCategory {
  TRAVEL
  FOOD
  INTERNET
  MISCELLANEOUS
}

enum ClaimStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ClearanceStatus {
  PENDING
  CLEARED
}

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  USED
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum DocCategory {
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  KYC
  CONTRACT
  PAYSLIP
  OTHER
}

enum EmploymentStatus {
  PENDING_JOIN
  PROBATION
  INTERNSHIP
  REGULAR_FULL_TIME
  NOTICE_PERIOD
  INACTIVE
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  SETTLED
  CANCELLED
}

enum ImportStatus {
  PREVIEWED
  IMPORTED
  PARTIALLY_IMPORTED
  ROLLED_BACK
}

enum ImportType {
  ATTENDANCE
  EMPLOYEE_BULK
  ASSET_BULK
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  CLOSED
  REJECTED
}

enum PayrollRunType {
  REGULAR
  FULL_AND_FINAL
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  FINALIZED
}

enum PolicyScope {
  GLOBAL
  COMPANY_SPECIFIC
}

enum RevisionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ServiceRequestCategory {
  SALARY_ISSUE
  ATTENDANCE_CORRECTION
  DOCUMENT_REQUEST
  REIMBURSEMENT_ISSUE
  LEAVE_CORRECTION
  LETTER_REQUEST
  IT_SUPPORT
  OTHER
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
