generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AbsenceRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  markedBy  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdBy String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  prefix     String    @unique
  createdBy  String
  isActive   Boolean   @default(true)
  scopes     Json
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Asset {
  id           String            @id @default(cuid())
  name         String
  assetTag     String            @unique
  category     AssetCategory
  serialNumber String?
  purchaseDate DateTime?
  purchaseCost Float?
  status       AssetStatus       @default(AVAILABLE)
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignments  AssetAssignment[]
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  userId       String
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  conditionOut String?
  conditionIn  String?
  notes        String?
  assignedBy   String
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@index([userId])
}

model AttendanceAdjustment {
  id             String   @id @default(cuid())
  userId         String
  month          Int
  year           Int
  adjustmentDays Float
  reason         String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model AttendanceImport {
  id             String             @id @default(cuid())
  month          Int
  year           Int
  fileName       String
  importedBy     String
  recordCount    Int
  unmappedEnNos  Json
  arrivalTime    String?
  extensionDates Json               @default("[]")
  createdAt      DateTime           @default(now())
  records        AttendanceRecord[]

  @@unique([month, year])
}

model AttendanceRecord {
  id            String           @id @default(cuid())
  userId        String
  importId      String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  hoursWorked   Float?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  checkInManual DateTime?
  isLate        Boolean          @default(false)
  lwpDeduction  Float            @default(0)
  import        AttendanceImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  action        String
  entity        String
  entityId      String?
  subjectEntity String?
  subjectId     String?
  subjectLabel  String?
  subjectMeta   Json?
  oldValues     Json?
  newValues     Json?
  reason        String?
  changeSource  String?
  createdAt     DateTime @default(now())
  actor         User     @relation(fields: [actorId], references: [id])
}

model BackupLog {
  id          String   @id @default(cuid())
  triggeredBy String
  status      String
  fileName    String?
  commitSha   String?
  fileSizeKb  Int?
  error       String?
  createdAt   DateTime @default(now())
}

model CompOff {
  id         String        @id @default(cuid())
  userId     String
  earnedDate DateTime
  reason     String
  status     CompOffStatus @default(PENDING)
  approvedBy String?
  usedOn     DateTime?
  expiresAt  DateTime
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id])

  @@unique([userId, earnedDate])
}

model Company {
  id             String                      @id @default(cuid())
  code           String                      @unique
  legalName      String
  displayName    String
  payrollPrefix  String?
  pan            String?
  tan            String?
  gstin          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  pincode        String?
  logoUrl        String?
  isActive       Boolean                     @default(true)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  assignments    EmployeeCompanyAssignment[]
  payrollRuns    PayrollRun[]
  policyVersions PolicyVersion[]
}

model DeclaredWFH {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdBy String
  createdAt DateTime @default(now())
}

model DelegateApprover {
  id          String   @id @default(cuid())
  delegatorId String
  delegateId  String
  fromDate    DateTime
  toDate      DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  delegate    User     @relation("DelegateApprover_delegateIdToUser", fields: [delegateId], references: [id])
  delegator   User     @relation("DelegateApprover_delegatorIdToUser", fields: [delegatorId], references: [id])
}

model EmployeeCompanyAssignment {
  id                 String           @id @default(cuid())
  userId             String
  companyId          String
  employeeCode       String?
  designation        String?
  department         String?
  reportingManagerId String?
  annualCTC          Float?
  employmentType     String?
  joiningDate        DateTime?
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  isPrimary          Boolean          @default(true)
  status             AssignmentStatus @default(ACTIVE)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company          @relation(fields: [companyId], references: [id])
  reportingManager   User?            @relation("EmployeeCompanyAssignment_reportingManagerIdToUser", fields: [reportingManagerId], references: [id])
  user               User             @relation("EmployeeCompanyAssignment_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId, status])
}

model EmployeeDocument {
  id             String      @id @default(cuid())
  userId         String
  category       DocCategory @default(OTHER)
  name           String
  fileUrl        String
  description    String?
  uploadedBy     String
  expiryDate     DateTime?
  isRequired     Boolean     @default(false)
  reminderSentAt DateTime?
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExitClearance {
  id            String          @id @default(cuid())
  exitRequestId String
  department    String
  clearedBy     String?
  status        ClearanceStatus @default(PENDING)
  remarks       String?
  clearedAt     DateTime?
  createdAt     DateTime        @default(now())
  exitRequest   ExitRequest     @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
}

model ExitRequest {
  id               String           @id @default(cuid())
  userId           String           @unique
  initiatedBy      String
  reason           String
  lastWorkingDate  DateTime
  noticePeriodDays Int
  buyoutDays       Int?
  buyoutAmount     Float?
  status           ExitStatus       @default(INITIATED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  clearances       ExitClearance[]
  user             User             @relation(fields: [userId], references: [id])
  settlement       FinalSettlement?
}

model FinalSettlement {
  id                      String      @id @default(cuid())
  exitRequestId           String      @unique
  lastMonthSalaryProrated Float
  leaveEncashmentDays     Float
  leaveEncashmentAmount   Float
  pendingClaimsAmount     Float       @default(0)
  arrearsPending          Float       @default(0)
  bonusPending            Float       @default(0)
  noticePeriodRecovery    Float       @default(0)
  loanOutstanding         Float       @default(0)
  otherDeductions         Float       @default(0)
  totalPayable            Float
  processedBy             String?
  processedAt             DateTime?
  createdAt               DateTime    @default(now())
  exitRequest             ExitRequest @relation(fields: [exitRequestId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  type      String?
  createdAt DateTime @default(now())
}

model ImportBatch {
  id          String       @id @default(cuid())
  type        ImportType
  uploadedBy  String
  fileName    String
  totalRows   Int
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  status      ImportStatus @default(PREVIEWED)
  errorLog    String?
  notes       String?
  createdAt   DateTime     @default(now())
}

model LeaveBalance {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  leaveType String
  total     Float
  used      Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, leaveType])
}

model LeavePolicy {
  id                  String   @id @default(cuid())
  leaveType           String   @unique
  label               String
  defaultTotal        Int
  isActive            Boolean  @default(true)
  isUnlimited         Boolean  @default(false)
  documentRequired    Boolean  @default(false)
  documentAfterDays   Int?
  carryForwardEnabled Boolean  @default(false)
  carryForwardMaxDays Int?
  encashable          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LeaveRequest {
  id             String        @id @default(cuid())
  employeeId     String
  managerId      String?
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  totalDays      Float
  reason         String
  status         LeaveStatus   @default(PENDING)
  managerComment String?
  approvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  durationType   String?
  singleDayType  String?
  startDayType   String?
  endDayType     String?
  employee       User          @relation("LeaveRequest_employeeIdToUser", fields: [employeeId], references: [id])
  manager        User?         @relation("LeaveRequest_managerIdToUser", fields: [managerId], references: [id])
  travelProofs   TravelProof[]
}

model LoanRequest {
  id               String     @id @default(cuid())
  userId           String
  amount           Float
  installments     Int
  monthlyEMI       Float
  interestRate     Float      @default(9.0)
  reason           String
  status           LoanStatus @default(PENDING)
  approvedBy       String?
  approvedAt       DateTime?
  startMonth       Int?
  startYear        Int?
  paidInstallments Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayrollComponent {
  id        String        @id @default(cuid())
  name      String        @unique
  type      ComponentType
  calcType  CalcType
  value     Float         @default(0)
  isActive  Boolean       @default(true)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PayrollRun {
  id              String         @id @default(cuid())
  month           Int
  year            Int
  status          PayrollStatus  @default(DRAFT)
  processedBy     String
  companyId       String?
  policyVersionId String?
  runType         PayrollRunType @default(REGULAR)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company?       @relation(fields: [companyId], references: [id])
  policyVersion   PolicyVersion? @relation(fields: [policyVersionId], references: [id])
  entries         PayslipEntry[]

  @@unique([month, year, companyId, runType])
}

model PayslipEntry {
  id                  String     @id @default(cuid())
  payrollRunId        String
  userId              String
  monthlyCtc          Float
  workingDays         Int
  lwpDays             Float      @default(0)
  paidDays            Float
  earnings            Json
  deductions          Json
  reimbursements      Float      @default(0)
  grossPay            Float
  totalDeductions     Float
  netPay              Float
  companyLegalName    String?
  companyAddress      String?
  companyPan          String?
  employeeCode        String?
  designationSnapshot String?
  arrearsAmount       Float?     @default(0)
  arrearsNote         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  user                User       @relation(fields: [userId], references: [id])

  @@unique([payrollRunId, userId])
}

model PolicyAcknowledgement {
  id              String        @id @default(cuid())
  policyVersionId String
  userId          String
  acknowledgedAt  DateTime?
  isAcknowledged  Boolean       @default(false)
  createdAt       DateTime      @default(now())
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([policyVersionId, userId])
}

model PolicyRule {
  id              String        @id @default(cuid())
  policyVersionId String
  ruleKey         String
  ruleValue       String
  valueType       String
  description     String?
  createdAt       DateTime      @default(now())
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)

  @@unique([policyVersionId, ruleKey])
}

model PolicyVersion {
  id               String                  @id @default(cuid())
  name             String
  versionCode      String                  @unique
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  isActive         Boolean                 @default(false)
  scope            PolicyScope             @default(GLOBAL)
  companyId        String?
  notes            String?
  publishedBy      String?
  publishedAt      DateTime?
  createdAt        DateTime                @default(now())
  payrollRuns      PayrollRun[]
  acknowledgements PolicyAcknowledgement[]
  rules            PolicyRule[]
  company          Company?                @relation(fields: [companyId], references: [id])
}

model Profile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  firstName            String
  middleName           String?
  lastName             String
  dateOfBirth          DateTime?
  gender               String?
  bloodGroup           String?
  personalEmail        String?
  phone                String?
  secondaryPhone       String?
  emergencyContact     String?
  employeeId           String    @unique
  designation          String    @default("")
  department           String    @default("")
  dateOfJoining        DateTime?
  officeLocation       String?   @default("Kolkata")
  managerId            String?
  pan                  String?
  aadharNumber         String?
  uan                  String?
  bankAccountNumber    String    @default("")
  ifscCode             String    @default("")
  bankName             String    @default("")
  kycDocumentUrl       String?
  appointmentLetterUrl String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  annualCtc            Float     @default(0)
  employmentType       String    @default("FULL_TIME")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PunchMapping {
  id        String   @id @default(cuid())
  enNo      Int      @unique
  userId    String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id          String        @id @default(cuid())
  employeeId  String
  category    ClaimCategory
  amount      Float
  description String
  billUrl     String?
  status      ClaimStatus   @default(PENDING)
  paidAt      DateTime?
  paidNote    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    User          @relation(fields: [employeeId], references: [id])
}

model SalaryRevision {
  id            String         @id @default(cuid())
  userId        String
  effectiveDate DateTime
  oldCtc        Float
  newCtc        Float
  reason        String?
  revisedBy     String
  status        RevisionStatus @default(PENDING)
  proposedBy    String
  approvedBy    String?
  createdAt     DateTime       @default(now())
  revisor       User           @relation("SalaryRevision_revisedByToUser", fields: [revisedBy], references: [id])
  user          User           @relation("SalaryRevision_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceRequest {
  id          String                 @id @default(cuid())
  userId      String
  category    ServiceRequestCategory
  subject     String
  description String
  status      ServiceRequestStatus   @default(OPEN)
  assignedTo  String?
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  user        User                   @relation(fields: [userId], references: [id])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model TravelProof {
  id             String       @id @default(cuid())
  leaveRequestId String
  userId         String
  proofDate      DateTime
  geoLat         Float?
  geoLng         Float?
  mapsLink       String?
  submittedAt    DateTime?
  createdAt      DateTime     @default(now())
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([leaveRequestId, proofDate])
}

model User {
  id                     String                      @id @default(cuid())
  email                  String                      @unique
  password               String
  role                   Role                        @default(EMPLOYEE)
  isActive               Boolean                     @default(true)
  employmentStatus       EmploymentStatus            @default(REGULAR_FULL_TIME)
  adminScope             String?
  visibilityScope        String?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  absenceRecords         AbsenceRecord[]
  assetAssignments       AssetAssignment[]
  attendanceAdjustments  AttendanceAdjustment[]
  attendanceRecords      AttendanceRecord[]
  auditLogs              AuditLog[]
  compOffs               CompOff[]
  delegationsAsDelegate  DelegateApprover[]          @relation("DelegateApprover_delegateIdToUser")
  delegationsAsDelegator DelegateApprover[]          @relation("DelegateApprover_delegatorIdToUser")
  companyAssignments     EmployeeCompanyAssignment[] @relation("EmployeeCompanyAssignment_userIdToUser")
  managedAssignments     EmployeeCompanyAssignment[] @relation("EmployeeCompanyAssignment_reportingManagerIdToUser")
  employeeDocuments      EmployeeDocument[]
  exitRequest            ExitRequest?
  leaveBalances          LeaveBalance[]
  leavesAsEmployee       LeaveRequest[]              @relation("LeaveRequest_employeeIdToUser")
  leavesAsManager        LeaveRequest[]              @relation("LeaveRequest_managerIdToUser")
  loanRequests           LoanRequest[]
  notifications          Notification[]
  payslipEntries         PayslipEntry[]
  policyAcknowledgements PolicyAcknowledgement[]
  profile                Profile?
  punchMapping           PunchMapping?
  reimbursements         Reimbursement[]
  revisedSalaries        SalaryRevision[]            @relation("SalaryRevision_revisedByToUser")
  salaryRevisions        SalaryRevision[]            @relation("SalaryRevision_userIdToUser")
  serviceRequests        ServiceRequest[]
  travelProofs           TravelProof[]
  workLogs               WorkLog[]
}

model WorkLog {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime
  content       String
  status        String    @default("APPROVED")
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum AssetCategory {
  LAPTOP
  PHONE
  CHARGER
  MONITOR
  KEYBOARD
  MOUSE
  SIM_CARD
  ACCESS_CARD
  ID_CARD
  SOFTWARE_LICENSE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

enum AssignmentStatus {
  ACTIVE
  TRANSFERRED
  CLOSED
}

enum CalcType {
  PERCENTAGE_OF_CTC
  FIXED
  MANUAL
  AUTO_PT
  AUTO_TDS
}

enum ClaimCategory {
  TRAVEL
  FOOD
  INTERNET
  MISCELLANEOUS
}

enum ClaimStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum ClearanceStatus {
  PENDING
  CLEARED
}

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  USED
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum DocCategory {
  OFFER_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  KYC
  CONTRACT
  PAYSLIP
  OTHER
}

enum EmploymentStatus {
  PENDING_JOIN
  PROBATION
  INTERNSHIP
  REGULAR_FULL_TIME
  NOTICE_PERIOD
  INACTIVE
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  SETTLED
  CANCELLED
}

enum ImportStatus {
  PREVIEWED
  IMPORTED
  PARTIALLY_IMPORTED
  ROLLED_BACK
}

enum ImportType {
  ATTENDANCE
  EMPLOYEE_BULK
  ASSET_BULK
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LoanStatus {
  PENDING
  APPROVED
  ACTIVE
  CLOSED
  REJECTED
}

enum PayrollRunType {
  REGULAR
  FULL_AND_FINAL
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  FINALIZED
}

enum PolicyScope {
  GLOBAL
  COMPANY_SPECIFIC
}

enum RevisionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ServiceRequestCategory {
  SALARY_ISSUE
  ATTENDANCE_CORRECTION
  DOCUMENT_REQUEST
  REIMBURSEMENT_ISSUE
  LEAVE_CORRECTION
  LETTER_REQUEST
  IT_SUPPORT
  OTHER
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
